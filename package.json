{
  "name": "bart-ui",
  "type": "module",
  "private": true,
  "workspaces": [
    "registry",
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "test": "bun test",
    "test:e2e": "bun run --cwd apps/playground test:e2e",
    "typecheck": "tsc -p registry && tsc -p packages/cli && tsc -b apps/playground",
    "cli:build": "bun run --cwd packages/cli build",
    "playground": "bun run --cwd apps/playground dev"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
